{
  "name": "uuhakix-blockchain",
  "version": "1.0.0",
  "description": "UUUHAKIX Smart Contracts — Polygon deployment",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network polygon-amoy",
    "deploy:mainnet": "npx hardhat run scripts/deploy.js --network polygon-mainnet",
    "verify": "npx hardhat verify --network polygon-amoy"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "hardhat": "^2.22.10",
    "dotenv": "^16.4.5"
  }
}
