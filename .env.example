# ============================================================
# UHAKIX — Environment Variables
# Copy to .env and fill in actual values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=UHAKIX
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=change-this-to-32-char-random-secret
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,https://uhakix.ke

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://uhakix:uhakix_password@postgres:5432/uhakix
POSTGRES_USER=uhakix
POSTGRES_PASSWORD=uhakix_password
POSTGRES_DB=uhakix

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_RATE_LIMIT_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

# ── Neo4j Graph Database ─────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_secure

# ── NVIDIA NIM API ───────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-api-key-here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions

# AI Models
MODEL_COMPLEX_ANALYSIS=nvidia/nemotron-4-340b-instruct
MODEL_GENERAL=meta/llama-3.1-70b-instruct
MODEL_LIGHTWEIGHT=meta/llama-3.1-8b-instruct
MODEL_VISION=meta/llama-3.2-90b-vision-instruct
MODEL_EDGE=microsoft/phi-3.5-mini-instruct

# ── Blockchain (Polygon) ─────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CHAIN_ID=137
BLOCKCHAIN_PRIVATE_KEY=your-wallet-private-key
TRANSPARENCY_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000

# ── WhatsApp Integration (Web via QR Code) ───────────────────
# UHAKIX connects like OpenClaw — scan QR to link device
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./data/whatsapp-session
WHATSAPP_AUTO_RECONNECT=true

# ── Telegram Bot Integration ─────────────────────────────────
# Token from @BotFather - Citizens search @UhakixBot to use UHAKIX
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=8570592603:AAH8cj-HSRXWZZCJOvRPtM5vQmP0uwAlwCA
TELEGRAM_WEBHOOK_URL=https://uhakix.ke/api/v1/citizen/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=change-this-to-random-secret

# ── E-Citizen Integration ────────────────────────────────────
ECITIZEN_API_URL=https://accounts.go.ke/api
ECITIZEN_API_KEY=your-e-citizen-api-key

# ── IFMIS Integration ───────────────────────────────────────
IFMIS_API_URL=https://www.ifmis.go.ke/api
IFMIS_USERNAME=
IFMIS_PASSWORD=

# ── Tenders.go.ke Integration ───────────────────────────────
TENDERS_API_URL=https://tenders.go.ke/api

# ── Controller of Budget ─────────────────────────────────────
COB_API_URL=https://www.controllerofbudget.go.ke/api

# ── Email (for alerts) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@uhakix.ke
SMTP_PASSWORD=your-smtp-password

# ── Sentry (error tracking) ─────────────────────────────────
SENTRY_DSN=

# ── Voice Models ─────────────────────────────────────────────
VOICE_STT_MODEL=openai/whisper-large-v3
VOICE_TTS_MODEL=facebook/mms-tts
VOICE_SHENG_GLOSSARY_PATH=./data/sheng-glossary.csv
VOICE_MAX_AUDIO_LENGTH=300
VOICE_LANGUAGE_FALLBACK=sw

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
