# ============================================================
# UJUZIO — Environment Variables
# Copy to .env and fill in actual values
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=Ujuzio
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=change-this-to-32-char-random-secret
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,https://ujuzio.ke

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ujuzio:ujuzio_password@postgres:5432/ujuzio
POSTGRES_USER=ujuzio
POSTGRES_PASSWORD=ujuzio_password
POSTGRES_DB=ujuzio

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_RATE_LIMIT_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2

# ── Neo4j Graph Database ─────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_secure

# ── NVIDIA NIM API ───────────────────────────────────────────
NVIDIA_API_KEY=nvapi-XXXX
NVIDIA_NEMOTRON_4_340B=nvidia/nemotron-4-340b-instruct
NVIDIA_LLAMA_3_1_70B=meta/llama-3.1-70b-instruct
NVIDIA_LLAMA_3_1_8B=meta/llama-3.1-8b-instruct
NVIDIA_PHI_3_MINI=microsoft/phi-3-mini-128k-instruct
NVIDIA_LLAMA_3_2_VISION=nvidia/llama-3.2-90b-vision-instruct

# ── Blockchain (Polygon) ─────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_TESTNET_RPC=https://rpc-amoy.polygon.technology
ETHERSCAN_API_KEY=
BLOCKCHAIN_PRIVATE_KEY=
CONTRACT_ADDRESS=
BLOCKCHAIN_NETWORK=polygon-amoy
HASH_BATCH_THRESHOLD=50

# ── WhatsApp (Baileys) ───────────────────────────────────────
WHATSAPP_SESSION_DIR=./whatsapp-sessions
WHATSAPP_WEBHOOK_SECRET=

# ── USSD (Africa's Talking) ──────────────────────────────────
AT_API_KEY=
AT_USERNAME=your_username
AT_SHORTCODE=*789#

# ── Storage (S3-compatible) ──────────────────────────────────
S3_ENDPOINT_URL=https://
S3_BUCKET_NAME=ujuzio-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# ── Data Source Credentials ──────────────────────────────────
IFMIS_BASE_URL=https://ifmis.go.ke
TENDERS_BASE_URL=https://tenders.go.ke
COB_BASE_URL=https://controllerofbudget.go.ke
TREASURY_BASE_URL=https://treasury.go.ke
GAZETTE_BASE_URL=
IEBC_BASE_URL=https://results.iebc.or.ke
PARLIAMENT_BASE_URL=

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=grafana_admin

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
USSD_RATE_LIMIT_PER_MINUTE=5

# ── Election Config ──────────────────────────────────────────
ELECTION_VERIFICATION_MIN_SOURCES=3
ALERT_ANOMALY_THRESHOLD_STDDEV=3.0
FORM_34A_MAX_FILE_SIZE_MB=10
BLOCKCHAIN_CONFIRMATION_BLOCKS=6
